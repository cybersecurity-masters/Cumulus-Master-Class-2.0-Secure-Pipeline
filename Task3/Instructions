Build image
az acr build --registry masterclassregistry --image task3:v1-fixed .

Get credentials to the registry
az acr credential show --name masterclassregistry

Create container
az container create --resource-group  CumulusMasterclass --location westeurope --name task3 --image masterclassregistry.azurecr.io/task3:v1-fixed  --registry-username ? --registry-password ? --os-type Linux  --ports 8080 --vnet masterclassvnet --subnet containersubnet --ip-address Private --cpu 1 --memory 1 --restart-policy always

