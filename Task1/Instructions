Secure the container
RUN useradd -m appuser
USER appuser

Build the image
az acr build --registry masterclassregistry --image task1:v1-fixed .

Get credentials to the registry
az acr credential show --name masterclassregistry

Create a container
az container create --resource-group CumulusMasterclass --location westeurope --name task1 --image masterclassregistry.azurecr.io/task1:v1-fixed  --registry-username ? --registry-password ? --os-type Linux  --ports 8080 --vnet masterclassvnet --subnet containersubnet --ip-address Private --cpu 1 --memory 1 --restart-policy always

Check for communication with judge!

