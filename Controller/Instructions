Create a VNET
az network vnet create --resource-group CumulusMasterclass  --location westeurope --name masterclassvnet  --address-prefix 172.168.0.0/16  --subnet-name containersubnet  --subnet-prefix 172.168.10.0/28

Delagate a subnet
az network vnet subnet update --resource-group CumulusMasterclass --vnet-name masterclassvnet --name containersubnet --delegations Microsoft.ContainerInstance/containerGroups

Check credentials to registry
az acr credential show --name masterclassregistry

Create judge container 
az container create --resource-group CumulusMasterclass --location westeurope --name judge --image masterclassregistry.azurecr.io/judge:v1 --registry-username ? --registry-password ? --os-type Linux --vnet masterclassvnet --subnet containersubnet --ip-address Private --cpu 1 --memory 1 --restart-policy always

Check for connection
az container exec --name judge --resource-group CumulusMasterclass --exec-command "tail -f /tmp/judge.log"

